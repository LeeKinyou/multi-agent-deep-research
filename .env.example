# ============================================================
# Multi-Agent Deep Research - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# Never commit .env to version control - it contains sensitive credentials!
# ============================================================

# ============================================================
# LLM Configuration (Text Generation)
# ============================================================
# Choose ONE of the following options:

# --- Option 1: LM Studio Local Model (Recommended for local development) ---
# Download LM Studio: https://lmstudio.ai/
# Load any OpenAI-compatible local model (Qwen, Llama, etc.)
LLM_PROVIDER=openai
LLM_API_KEY=lm-studio
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=qwen3.5-9b
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# --- Option 2: DeepSeek Cloud Model ---
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your_deepseek_api_key_here
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096

# --- Option 3: OpenAI Cloud Model ---
# LLM_PROVIDER=openai
# LLM_API_KEY=your_openai_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096

# ============================================================
# Vision Model Configuration (Multimodal Analysis)
# ============================================================
# VISION_PROVIDER: Choose your vision model provider
#   Supported values: qwen-vl | openai | anthropic | google
#
# --- Qwen-VL (Local Deployment - Recommended, Free) ---
# Run with LM Studio, Ollama, or vLLM
VISION_PROVIDER=qwen-vl
VISION_MODEL_NAME=qwen2.5-vl-7b-instruct
VISION_BASE_URL=http://localhost:1234/v1
VISION_API_KEY=not-needed
#
# --- Qwen-VL (DashScope Cloud) ---
# Get API key: https://dashscope.console.aliyun.com/
# VISION_PROVIDER=qwen-vl
# VISION_MODEL_NAME=qwen-vl-max
# VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VISION_API_KEY=your_dashscope_api_key_here
#
# --- OpenAI GPT-4V / GPT-4o ---
# Get API key: https://platform.openai.com/
# VISION_PROVIDER=openai
# VISION_MODEL_NAME=gpt-4o
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_API_KEY=your_openai_api_key_here
#
# --- Anthropic Claude 3 ---
# Get API key: https://console.anthropic.com/
# VISION_PROVIDER=anthropic
# VISION_MODEL_NAME=claude-3-5-sonnet-20241022
# VISION_BASE_URL=https://api.anthropic.com
# VISION_API_KEY=your_anthropic_api_key_here
#
# --- Google Gemini ---
# Get API key: https://aistudio.google.com/
# VISION_PROVIDER=google
# VISION_MODEL_NAME=gemini-2.0-flash
# VISION_BASE_URL=
# VISION_API_KEY=your_google_api_key_here

# ============================================================
# Search Tool Configuration
# ============================================================
# DuckDuckGo (free, no API key required)
SEARCH_TOOL=duckduckgo
#
# Tavily (requires API key, better quality)
# Get API key: https://tavily.com/
# SEARCH_TOOL=tavily
# TAVILY_API_KEY=your_tavily_api_key_here

# ============================================================
# Database Configuration
# ============================================================
# SQLite (default, no setup required)
DATABASE_URL=sqlite:///./deep_research.db
#
# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@localhost/deep_research

# ============================================================
# Application Configuration
# ============================================================
DEBUG=true
LOG_LEVEL=INFO

# FastAPI Configuration
HOST=0.0.0.0
PORT=8000

# Chainlit Configuration
CHAINLIT_AUTH_SECRET=your_chainlit_auth_secret_here
# Generate with: openssl rand -base64 32

# ============================================================
# Observability (Optional)
# ============================================================
# Langfuse for LLM observability and evaluation
# Get keys: https://cloud.langfuse.com/ or self-hosted
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=https://cloud.langfuse.com
